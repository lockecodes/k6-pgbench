      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(k6_pgbench_tx_tpcb_latency_seconds{cluster=~\"$cluster\", namespace=~\"$namespace\", testid=~\"$testid\"}[$__rate_interval])))",
