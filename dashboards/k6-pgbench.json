      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 21,
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Error Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(k6_pgbench_errors_total{cluster=~\"$cluster\", namespace=~\"$namespace\", testid=~\"$testid\"}[$__rate_interval])",
          "legendFormat": "errors/s",
          "refId": "A"
        },
        {
          "expr": "k6_pgbench_errors_total{cluster=~\"$cluster\", namespace=~\"$namespace\", testid=~\"$testid\"}",
          "legendFormat": "cumulative",
          "refId": "B"
        }
      ]
